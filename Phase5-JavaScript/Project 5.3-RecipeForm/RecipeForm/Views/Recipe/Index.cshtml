@using RecipeForm.Models
@model Recipe

@{
    ViewData["Title"] = "Recipes";
}
<h1>@ViewData["Title"]</h1>

<form asp-action="Submit" method="post">
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="form-description">
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>
    <div id="ingredientList">
        <div class="input-group mb-2">
            <input type="text" name="Ingredients[0]" class="form-control" placeholder="Enter ingredient..." />
            <button type="button" class="btn btn-outline-danger remove-btn">Remove</button>
        </div>
    </div>
</form>

@section Scripts {
    <script src="~/js/recipe-form.js"></script>
}

