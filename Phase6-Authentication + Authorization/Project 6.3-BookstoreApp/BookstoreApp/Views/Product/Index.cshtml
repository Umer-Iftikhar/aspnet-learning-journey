@model IEnumerable<BookstoreApp.Models.Product>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Product Inventory</h2>

        @* HIDE "Add New Product" FROM CUSTOMERS *@
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">Add New Product</a>
        }
    </div>
    <hr />

    <table class="table table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Name)</th>
                <th>@Html.DisplayNameFor(model => model.Price)</th>
                <th>@Html.DisplayNameFor(model => model.Stock)</th>
                <th>Description</th>

                @* HIDE HEADER COLUMN FROM CUSTOMERS *@
                @if (User.IsInRole("Admin"))
                {
                    <th class="text-center">Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@item.Stock</td>
                    <td class="text-truncate" style="max-width: 200px;">@item.Description</td>

                    @* HIDE BUTTONS FROM CUSTOMERS *@
                    @if (User.IsInRole("Admin"))
                    {
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>